{
  "$schema": "suswe-device-profile/v1",
  "id": "suswe-su900",
  "name": "SUSWE SU800/SU900",
  "description": "Variador de frecuencia vectorial SUSWE serie SU800/SU900. Protocolo Modbus RTU/TCP, FC 0x03/0x06.",
  "manufacturer": "SUSWE",
  "models": ["SU800", "SU900"],
  "version": "1.0.0",

  "modbus": {
    "defaultBaudRate": 9600,
    "defaultParity": "none",
    "defaultDataBits": 8,
    "defaultStopBits": 2,
    "defaultSlaveId": 1,
    "readFC": 3,
    "writeFC": 6,
    "maxBlockRead": 12
  },

  "controlRegisters": {
    "freqSetpoint": { "addr": "0x1000", "note": "Consigna de frecuencia por comunicación. Rango: -10000~10000 = -100.00%~100.00% de frec. máxima." },
    "command":      { "addr": "0x2000", "note": "Comando de marcha/paro." },
    "doControl":    { "addr": "0x2001", "note": "Control salidas digitales DO." },
    "ao1Control":   { "addr": "0x2002", "note": "Control AO1. 0~0x7FFF = 0~100%." },
    "ao2Control":   { "addr": "0x2003", "note": "Control AO2." },
    "fmpControl":   { "addr": "0x2004", "note": "Control FMP (pulso)." },
    "runStatus":    { "addr": "0x3000", "note": "Estado de funcionamiento. bit0=FWD, bit1=REV." },
    "faultCode":    { "addr": "0x8000", "note": "Código de falla activa. 0=sin falla." }
  },

  "commandValues": {
    "RUN_FORWARD": 1,
    "RUN_REVERSE": 2,
    "JOG_FORWARD": 3,
    "JOG_REVERSE": 4,
    "FREE_STOP":   5,
    "RAMP_STOP":   6,
    "FAULT_RESET": 7
  },

  "monitorBlock": {
    "startAddr": "0x1001",
    "count": 32,
    "registers": [
      { "code": "U0-00", "offset": 0,  "name": "Frecuencia de salida",         "scale": 0.01, "unit": "Hz"  },
      { "code": "U0-01", "offset": 1,  "name": "Tensión bus DC",               "scale": 1,    "unit": "V"   },
      { "code": "U0-02", "offset": 2,  "name": "Tensión de salida",            "scale": 1,    "unit": "V"   },
      { "code": "U0-03", "offset": 3,  "name": "Corriente de salida",          "scale": 0.1,  "unit": "A"   },
      { "code": "U0-04", "offset": 4,  "name": "Potencia de salida",           "scale": 0.1,  "unit": "kW"  },
      { "code": "U0-05", "offset": 5,  "name": "Par de salida",                "scale": 0.1,  "unit": "%"   },
      { "code": "U0-06", "offset": 6,  "name": "Velocidad de funcionamiento",  "scale": 1,    "unit": "rpm" },
      { "code": "U0-07", "offset": 7,  "name": "Estado entradas digitales DI", "scale": 1,    "unit": ""    },
      { "code": "U0-08", "offset": 8,  "name": "Estado salidas digitales DO",  "scale": 1,    "unit": ""    },
      { "code": "U0-09", "offset": 9,  "name": "Voltaje AI1",                  "scale": 0.01, "unit": "V"   },
      { "code": "U0-10", "offset": 10, "name": "Voltaje AI2",                  "scale": 0.01, "unit": "V"   },
      { "code": "U0-11", "offset": 11, "name": "Voltaje AI3",                  "scale": 0.01, "unit": "V"   },
      { "code": "U0-16", "offset": 15, "name": "Consigna PID",                 "scale": 0.01, "unit": "%"   },
      { "code": "U0-17", "offset": 16, "name": "Retroalimentación PID",        "scale": 0.01, "unit": "%"   },
      { "code": "U0-19", "offset": 26, "name": "Velocidad real motor",         "scale": 1,    "unit": "rpm" },
      { "code": "U0-31", "offset": 31, "name": "Frecuencia auxiliar Y",        "scale": 0.01, "unit": "Hz"  }
    ]
  },

  "faultHistoryAddrs": ["0x900E", "0x900F", "0x9010"],

  "faultMap": {
    "0x0001": { "name": "Reservado",                            "severity": "low"  },
    "0x0002": { "name": "Sobrecorriente en aceleración",        "severity": "high" },
    "0x0003": { "name": "Sobrecorriente en desaceleración",     "severity": "high" },
    "0x0004": { "name": "Sobrecorriente a velocidad constante", "severity": "high" },
    "0x0005": { "name": "Sobretensión en aceleración",          "severity": "high" },
    "0x0006": { "name": "Sobretensión en desaceleración",       "severity": "high" },
    "0x0007": { "name": "Sobretensión a velocidad constante",   "severity": "high" },
    "0x0008": { "name": "Error sobrecarga buffer",              "severity": "med"  },
    "0x0009": { "name": "Sin tensión (bajo voltaje)",           "severity": "med"  },
    "0x000A": { "name": "Sobrecalentamiento inverter",          "severity": "high" },
    "0x000B": { "name": "Sobrecarga motor",                     "severity": "med"  },
    "0x000C": { "name": "Falta de fase en entrada",             "severity": "high" },
    "0x000D": { "name": "Falta de fase en salida",              "severity": "high" },
    "0x000E": { "name": "Sobrecalentamiento módulo",            "severity": "high" },
    "0x000F": { "name": "Falla externa",                        "severity": "med"  },
    "0x0010": { "name": "Anomalía de comunicación",             "severity": "med"  },
    "0x0011": { "name": "Contactor anormal",                    "severity": "med"  },
    "0x0012": { "name": "Falla detección de corriente",         "severity": "high" },
    "0x0013": { "name": "Falla sintonización motor",            "severity": "med"  },
    "0x0015": { "name": "Anomalía lectura/escritura EEPROM",    "severity": "med"  },
    "0x0016": { "name": "Falla hardware convertidor",           "severity": "high" },
    "0x0017": { "name": "Cortocircuito motor a tierra",         "severity": "high" },
    "0x001A": { "name": "Error en tiempo de ejecución",         "severity": "med"  },
    "0x001B": { "name": "Error definido por usuario 1",         "severity": "med"  },
    "0x001C": { "name": "Error definido por usuario 2",         "severity": "med"  },
    "0x001D": { "name": "Tiempo de encendido alcanzado",        "severity": "low"  },
    "0x001F": { "name": "PID sin retroalimentación (timeout)",  "severity": "med"  },
    "0x0028": { "name": "Límite de corriente rápida (timeout)", "severity": "high" },
    "0x0029": { "name": "Falla motor en conmutación",           "severity": "med"  },
    "0x002A": { "name": "Desviación de velocidad excesiva",     "severity": "med"  },
    "0x002B": { "name": "Motor acelerando anormalmente",        "severity": "med"  }
  },

