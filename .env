# ─── Servidor ────────────────────────────────────────────
PORT=3000

# ─── Modbus RTU (RS485) ───────────────────────────────────
RTU_PORT=/dev/ttyUSB0
RTU_BAUDRATE=9600
RTU_PARITY=none
RTU_DATABITS=8
RTU_STOPBITS=2
RTU_SLAVE_ID=1

# ─── Modbus TCP ───────────────────────────────────────────
TCP_HOST=192.168.1.41
TCP_PORT=502
TCP_UNIT_ID=1

# ─── Timeouts y reintentos ────────────────────────────────
MODBUS_TIMEOUT=1000
MODBUS_RETRIES=3

# ─── Logger ──────────────────────────────────────────────
LOG_LEVEL=info

# ─── Autenticación HTTP Basic ─────────────────────────────
# AUTH_ENABLED=false  → sin autenticación (acceso libre)
# AUTH_ENABLED=true   → requiere usuario/contraseña en todas las rutas de la API
# Configurar desde el panel Seguridad/Auth de la UI o editando estas variables.
AUTH_ENABLED=false
AUTH_USERNAME=
AUTH_PASSWORD=
